#!/bin/sh
msg=$(head -1 "$1")
if ! echo "$msg" | grep -qE '^(feat|fix|docs|refactor|test|chore|ci|build|perf|style|revert)(\(.+\))?: .+'; then
  echo "ERROR: Commit message must follow Conventional Commits format:"
  echo "  <type>[optional scope]: <description>"
  echo "  Types: feat, fix, docs, refactor, test, chore, ci, build, perf, style, revert"
  exit 1
fi
